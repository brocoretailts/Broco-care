# Broco Smart Care - Environment Configuration
# Copy this file to .env and adjust values

# Session secret (change this in production!)
SESSION_SECRET=change-this-to-a-random-string

# Set to 'production' for secure cookies (HTTPS required)
NODE_ENV=development

# Server port (default: 3000)
PORT=3000

# Public URL for WhatsApp notification links (set to your Railway domain)
APP_URL=https://broco-care-production.up.railway.app
