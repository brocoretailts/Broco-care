<%- include('../partials/header') %>
<div class="d-flex">
  <%- include('../partials/sidebar') %>
  <main class="main-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h4 class="fw-bold mb-0"><i class="bi bi-speedometer2 me-2"></i>Dashboard Admin</h4>
      <span class="text-secondary small"><%= todayStr %></span>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-6 col-md-4 col-lg-2">
        <div class="card border-0 shadow-sm stat-card">
          <div class="card-body text-center p-3">
            <div class="stat-icon bg-warning bg-opacity-10 text-warning mb-2">📋</div>
            <div class="stat-value"><%= stats.complaint_hari_ini %></div>
            <div class="stat-label">Hari Ini</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-4 col-lg-2">
        <div class="card border-0 shadow-sm stat-card">
          <div class="card-body text-center p-3">
            <div class="stat-icon bg-warning text-white mb-2"><i class="bi bi-clock"></i></div>
            <div class="stat-value"><%= stats.waiting_approval %></div>
            <div class="stat-label">Waiting Approval</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-4 col-lg-2">
        <div class="card border-0 shadow-sm stat-card">
          <div class="card-body text-center p-3">
            <div class="stat-icon bg-primary text-white mb-2"><i class="bi bi-calendar"></i></div>
            <div class="stat-value"><%= stats.waiting_schedule %></div>
            <div class="stat-label">Waiting Schedule</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-4 col-lg-2">
        <div class="card border-0 shadow-sm stat-card">
          <div class="card-body text-center p-3">
            <div class="stat-icon bg-purple text-white mb-2"><i class="bi bi-gear"></i></div>
            <div class="stat-value"><%= stats.on_progress %></div>
            <div class="stat-label">On Progress</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-4 col-lg-2">
        <div class="card border-0 shadow-sm stat-card">
          <div class="card-body text-center p-3">
            <div class="stat-icon bg-success text-white mb-2"><i class="bi bi-check-circle"></i></div>
            <div class="stat-value"><%= stats.completed %></div>
            <div class="stat-label">Completed</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-4 col-lg-2">
        <div class="card border-0 shadow-sm stat-card">
          <div class="card-body text-center p-3">
            <div class="stat-icon bg-danger text-white mb-2"><i class="bi bi-x-circle"></i></div>
            <div class="stat-value"><%= stats.rejected %></div>
            <div class="stat-label">Rejected</div>
          </div>
        </div>
      </div>
    </div>

    <% if (overdueTickets.length > 0) { %>
    <div class="row g-3 mb-4">
      <div class="col-12">
        <div class="alert alert-danger border-0 shadow-sm d-flex align-items-center">
          <i class="bi bi-exclamation-triangle-fill me-3" style="font-size: 1.5rem;"></i>
          <div>
            <strong class="d-block">Perhatian! Ada <%= overdueTickets.length %> ticket yang belum selesai lebih dari 3 hari!</strong>
            <small>Segera tindak lanjuti ticket-ticket berikut:</small>
          </div>
        </div>
        <div class="table-responsive">
          <table class="table table-sm table-bordered bg-white rounded shadow-sm">
            <thead class="table-danger">
              <tr><th>Ticket</th><th>Customer</th><th>HP</th><th>Status</th><th>Hari</th><th></th></tr>
            </thead>
            <tbody>
              <% overdueTickets.forEach(function(t) { %>
              <tr>
                <td class="fw-semibold small"><%= t.ticket_no %></td>
                <td><%= t.customer_name %></td>
                <td><%= t.customer_hp %></td>
                <td>
                  <% var sMap = {waiting:['Waiting','warning'],approval:['Approval','warning text-white'],scheduled:['Scheduled','primary'],on_progress:['On Progress','purple']} %>
                  <% var ss = sMap[t.status] || ['Unknown','secondary'] %>
                  <span class="badge bg-<%= ss[1] %>"><%= ss[0] %></span>
                </td>
                <td class="text-danger fw-bold"><%= Math.round(t.hari) %> hari</td>
                <td><a href="/admin/tickets/<%= t.id %>" class="btn btn-sm btn-outline-danger"><i class="bi bi-eye"></i></a></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <% } %>

    <div class="row g-3">
      <div class="col-md-6">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white fw-semibold">Produk Paling Sering Complaint</div>
          <div class="card-body">
            <table class="table table-sm">
              <thead><tr><th>Produk</th><th class="text-end">Total</th></tr></thead>
              <tbody>
                <% topProducts.forEach(function(p) { %>
                <tr><td><%= p.nama_produk %></td><td class="text-end"><span class="badge bg-secondary"><%= p.total %></span></td></tr>
                <% }) %>
                <% if (topProducts.length === 0) { %><tr><td colspan="2" class="text-center text-secondary">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white fw-semibold">Rata-rata Waktu Penyelesaian</div>
          <div class="card-body text-center py-4">
            <div style="font-size: 3rem; font-weight: 700; color: var(--bs-primary);"><%= avgTime %> <small style="font-size: 1rem;">Hari</small></div>
            <p class="text-secondary small mt-2">Rata-rata waktu dari ticket dibuat hingga selesai</p>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
