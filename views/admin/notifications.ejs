<%- include('../partials/header') %>
<div class="d-flex">
  <%- include('../partials/sidebar') %>
  <main class="main-content">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h4 class="fw-bold mb-0"><i class="bi bi-bell me-2"></i>Notifikasi</h4>
      <div>
        <button class="btn btn-sm btn-outline-warning" onclick="deleteRead()"><i class="bi bi-trash"></i> Hapus Lama</button>
        <button class="btn btn-sm btn-outline-primary" onclick="markAllRead()"><i class="bi bi-check2-all"></i> Tandai Semua Dibaca</button>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="list-group list-group-flush">
        <% if (notifs.length === 0) { %>
        <div class="list-group-item text-center text-secondary py-4">Tidak ada notifikasi</div>
        <% } %>
        <% notifs.forEach(function(n) { %>
        <a href="<%= n.link || '#' %>" class="list-group-item list-group-item-action d-flex align-items-start gap-3 <%= n.is_read ? '' : 'fw-semibold' %>" onclick="markRead(<%= n.id %>)">
          <% if (n.is_read) { %>
          <span class="mt-1" style="flex-shrink:0;color:#0d6efd;"><i class="bi bi-check2-all"></i></span>
          <% } else { %>
          <span class="mt-1" style="flex-shrink:0;color:#666;"><i class="bi bi-check"></i></span>
          <% } %>
          <div class="flex-grow-1" style="min-width:0;">
            <div style="word-break:break-word;" class="<%= n.is_read ? 'text-secondary' : '' %>"><%= n.message %></div>
            <small class="text-secondary"><%= n.created_at %></small>
          </div>
        </a>
        <% }) %>
      </div>
    </div>
  </main>
</div>
<script>
function markAllRead() {
  fetch('/api/notifications/read-all', {method:'POST'}).then(function(r){return r.json()}).then(function(){location.reload()});
}
function deleteRead() {
  if (!confirm('Hapus notifikasi lama yang sudah dibaca?')) return;
  fetch('/api/notifications/delete-read', {method:'POST'}).then(function(r){return r.json()}).then(function(){location.reload()});
}
function markRead(id) {
  fetch('/api/notifications/read/' + id, {method:'POST'}).then(function(r){return r.json()});
}
</script>
<%- include('../partials/footer') %>