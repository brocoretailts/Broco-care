<%- include('../partials/header') %>
<div class="d-flex">
  <%- include('../partials/sidebar') %>
  <main class="main-content">
    <h4 class="fw-bold mb-4"><i class="bi bi-gear me-2"></i>Pengaturan</h4>

    <% if (query.success === 'password_changed') { %><div class="alert alert-success">Password berhasil diubah!</div><% } %>
    <% if (query.success === 'profile_updated') { %><div class="alert alert-success">Profil berhasil diperbarui!</div><% } %>
    <% if (query.success === 'user_updated') { %><div class="alert alert-success">User berhasil diperbarui!</div><% } %>
    <% if (query.success === 'user_created') { %><div class="alert alert-success">User baru berhasil ditambahkan!</div><% } %>
    <% if (query.success === 'user_deleted') { %><div class="alert alert-success">User berhasil dihapus!</div><% } %>
    <% if (query.success === 'restored') { %><div class="alert alert-success">Database berhasil direstore!</div><% } %>
    <% if (query.success === 'restore_pending') { %><div class="alert alert-info">Proses restore sedang berjalan...</div><% } %>
    <% if (query.success === 'reset_data') { %><div class="alert alert-success">Semua data transaksi berhasil dihapus!</div><% } %>
    <% if (query.success === 'reset_total') { %><div class="alert alert-success">Reset total berhasil! Aplikasi seperti baru.</div><% } %>
    <% if (query.success === 'terms_saved') { %><div class="alert alert-success">Ketentuan voucher berhasil disimpan!</div><% } %>
    <% if (query.error === 'wrong_password') { %><div class="alert alert-danger">Password saat ini salah!</div><% } %>
    <% if (query.error === 'password_mismatch') { %><div class="alert alert-danger">Password baru tidak cocok!</div><% } %>
    <% if (query.error && query.error.startsWith('Username')) { %><div class="alert alert-danger"><%= query.error %></div><% } %>
    <% if (query.error === 'password_short') { %><div class="alert alert-danger">Password minimal 4 karakter!</div><% } %>
    <% if (query.error === 'user_not_found') { %><div class="alert alert-danger">User tidak ditemukan!</div><% } %>
    <% if (query.error === 'cannot_delete_last_admin') { %><div class="alert alert-danger">Tidak bisa menghapus admin terakhir!</div><% } %>
    <% if (query.error === 'file_required') { %><div class="alert alert-danger">Pilih file database terlebih dahulu!</div><% } %>
    <% if (query.error === 'invalid_file') { %><div class="alert alert-danger">File harus berekstensi .sqlite!</div><% } %>
    <% if (query.error && query.error.startsWith('invalid_database')) { %><div class="alert alert-danger">File database tidak valid! <%= query.error.replace('invalid_database: ', '') %></div><% } %>
    <% if (query.error === 'restore_failed') { %><div class="alert alert-danger">Gagal merestore database. Coba lagi.</div><% } %>
    <% if (query.error === 'invalid_backup') { %><div class="alert alert-danger">File backup tidak valid! Pastikan file .zip berisi database.sqlite.</div><% } %>
    <% if (query.error && query.error.startsWith('upload_error')) { %><div class="alert alert-danger">Gagal upload: <%= query.error.replace('upload_error: ', '') %></div><% } %>

    <ul class="nav nav-tabs mb-3" id="settingsTabs">
      <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tabProfile">Profil Saya</a></li>
      <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabPassword">Ubah Password</a></li>
      <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabUsers">Kelola User</a></li>
      <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabBackup">Backup Data</a></li>
      <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabData">Data</a></li>
      <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabVoucher">Ketentuan Voucher</a></li>
    </ul>

    <div class="tab-content">
      <div class="tab-pane fade show active" id="tabProfile">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <form method="POST" action="/admin/settings/profile">
              <input type="hidden" name="_csrf" value="<%= csrf %>">
              <div class="row g-3">
                <div class="col-md-6"><label class="form-label small">Nama Lengkap</label><input name="name" class="form-control" value="<%= user.name %>" required></div>
                <div class="col-md-6"><label class="form-label small">Username</label><input class="form-control" value="<%= user.username %>" disabled></div>
                <div class="col-md-6"><label class="form-label small">No. HP (untuk WA)</label><input name="phone" class="form-control" value="<%= user.phone || '' %>" placeholder="08123456789"></div>
                <div class="col-md-6"><label class="form-label small">Email</label><input name="email" type="email" class="form-control" value="<%= user.email || '' %>"></div>
              </div>
              <button type="submit" class="btn btn-primary mt-3">Simpan Profil</button>
            </form>
          </div>
        </div>
      </div>

      <div class="tab-pane fade" id="tabPassword">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <form method="POST" action="/admin/settings/password">
              <input type="hidden" name="_csrf" value="<%= csrf %>">
              <div class="row g-3">
                <div class="col-md-4"><label class="form-label small">Password Saat Ini</label><input type="password" name="current_password" class="form-control" required></div>
                <div class="col-md-4"><label class="form-label small">Password Baru</label><input type="password" name="new_password" class="form-control" required></div>
                <div class="col-md-4"><label class="form-label small">Konfirmasi Password Baru</label><input type="password" name="confirm_password" class="form-control" required></div>
              </div>
              <button type="submit" class="btn btn-warning mt-3">Ubah Password</button>
            </form>
          </div>
        </div>
      </div>

      <div class="tab-pane fade" id="tabUsers">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <span></span>
          <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addUserModal"><i class="bi bi-plus"></i> Tambah User</button>
        </div>
        <div class="card border-0 shadow-sm">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr><th>Username</th><th>Nama</th><th>Role</th><th>No. HP</th><th>Email</th><th></th></tr>
              </thead>
              <tbody>
                <% admins.forEach(function(a) { %>
                <tr>
                  <td class="fw-semibold"><%= a.username %></td>
                  <td><%= a.name %></td>
                  <td><span class="badge bg-<%= a.role === 'admin' ? 'primary' : a.role === 'management' ? 'warning' : a.role === 'cs' ? 'success' : 'info' %>"><%= a.role.charAt(0).toUpperCase() + a.role.slice(1) %></span></td>
                  <td><%= a.phone || '-' %></td>
                  <td><%= a.email || '-' %></td>
                  <td><button class="btn btn-sm btn-outline-primary" onclick="editUser(<%= a.id %>, '<%= a.name.replace(/'/g,"\\'") %>', '<%= a.username %>', '<%= a.role %>', '<%= (a.phone||'').replace(/'/g,"\\'") %>', '<%= (a.email||'').replace(/'/g,"\\'") %>')" data-bs-toggle="modal" data-bs-target="#editUserModal"><i class="bi bi-pencil"></i></button>
                    <form method="POST" action="/admin/settings/user/<%= a.id %>/delete" onsubmit="return confirm('Hapus user <%= a.name.replace(/'/g,"\\'") %>?')" class="d-inline">
                      <input type="hidden" name="_csrf" value="<%= csrf %>">
                      <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                    </form>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="tab-pane fade" id="tabBackup">
        <div class="row g-3">
          <div class="col-md-6">
            <div class="card border-0 shadow-sm">
              <div class="card-header bg-white fw-semibold">Informasi Database</div>
              <div class="card-body">
                <table class="table table-sm">
                  <tr><td>Lokasi File</td><td class="font-monospace small"><%= dbPath %></td></tr>
                  <tr><td>Ukuran File</td><td><%= (dbSize / 1024).toFixed(1) %> KB</td></tr>
                  <tr><td>Ukuran Uploads</td><td><%= (uploadsSize / 1024 / 1024).toFixed(1) %> MB</td></tr>
                  <tr><td>Folder Uploads</td><td class="font-monospace small"><%= uploadsDir %></td></tr>
                </table>
              </div>
            </div>
            <div class="card border-0 shadow-sm mt-3">
              <div class="card-header bg-white fw-semibold">Backup Database (.sqlite)</div>
              <div class="card-body text-center py-3">
                <p class="small text-secondary">Hanya data database (tanpa file upload)</p>
                <a href="/admin/backup/download" class="btn btn-primary btn-sm"><i class="bi bi-download"></i> Download .sqlite</a>
              </div>
            </div>
            <div class="card border-0 shadow-sm mt-3">
              <div class="card-header bg-white fw-semibold">Backup Lengkap (.zip)</div>
              <div class="card-body text-center py-3">
                <p class="small text-secondary">Database + semua file upload (foto, video, dll)</p>
                <a href="/admin/backup/download-full" class="btn btn-success btn-sm"><i class="bi bi-download"></i> Download Full Backup (.zip)</a>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card border-0 shadow-sm">
              <div class="card-header bg-white fw-semibold">Restore Database (.sqlite)</div>
              <div class="card-body">
                <p class="small text-secondary">Upload file <strong>.sqlite</strong> — hanya data database.</p>
                <form method="POST" action="/admin/settings/restore" enctype="multipart/form-data">
                  <input type="hidden" name="_csrf" value="<%= csrf %>">
                  <div class="row g-2 align-items-end">
                    <div class="col-md-8">
                      <input type="file" name="database" class="form-control" accept=".sqlite" required>
                    </div>
                    <div class="col-md-4">
                      <button type="submit" class="btn btn-warning w-100" onclick="return confirm('Yakin ingin restore? Data saat ini akan diganti!')"><i class="bi bi-upload"></i> Restore</button>
                    </div>
                  </div>
                </form>
              </div>
            </div>
            <div class="card border-0 shadow-sm mt-3">
              <div class="card-header bg-white fw-semibold">Restore Lengkap (.zip)</div>
              <div class="card-body">
                <p class="small text-secondary">Upload file <strong>.zip</strong> — database + file upload kembali semua.</p>
                <form method="POST" action="/admin/settings/restore-full" enctype="multipart/form-data">
                  <input type="hidden" name="_csrf" value="<%= csrf %>">
                  <div class="row g-2 align-items-end">
                    <div class="col-md-8">
                      <input type="file" name="backup" class="form-control" accept=".zip" required>
                    </div>
                    <div class="col-md-4">
                      <button type="submit" class="btn btn-success w-100" onclick="return confirm('Yakin ingin restore lengkap? Semua data + uploads akan diganti!')"><i class="bi bi-upload"></i> Restore Full</button>
                    </div>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="tab-pane fade" id="tabData">
        <div class="row g-3">
          <div class="col-md-6">
            <div class="card border-0 shadow-sm">
              <div class="card-header bg-white fw-semibold text-danger"><i class="bi bi-exclamation-triangle me-1"></i> Hapus Data Transaksi</div>
              <div class="card-body">
                <p class="small text-secondary">Hapus semua ticket, kunjungan, log aktivitas, notifikasi, dan jadwal. <strong>User & produk tetap aman.</strong></p>
                <form method="POST" action="/admin/settings/reset-data" onsubmit="return confirm('HAPUS SEMUA TICKET?\n\nUser & produk tetap ada.\n\nData yang terhapus tidak bisa dikembalikan!')">
                  <input type="hidden" name="_csrf" value="<%= csrf %>">
                  <button type="submit" class="btn btn-outline-danger w-100"><i class="bi bi-trash3"></i> Hapus Semua Ticket</button>
                </form>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card border-0 shadow-sm">
              <div class="card-header bg-white fw-semibold text-danger"><i class="bi bi-skull me-1"></i> Reset Total</div>
              <div class="card-body">
                <p class="small text-secondary">Hapus <strong>SEMUA</strong> data termasuk user & produk. Aplikasi akan kembali seperti baru. Hanya akun admin utama yang tersisa.</p>
                <form method="POST" action="/admin/settings/reset-total" onsubmit="return confirm('RESET TOTAL PROGRAM?\n\nSEMUA DATA AKAN HAPUS!\nUser, produk, ticket, semua hilang.\nData tidak bisa dikembalikan!\n\nLanjutkan?')">
                  <input type="hidden" name="_csrf" value="<%= csrf %>">
                  <button type="submit" class="btn btn-danger w-100"><i class="bi bi-skull"></i> Reset Total</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="tab-pane fade" id="tabVoucher">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white fw-semibold"><i class="bi bi-file-earmark-text me-1"></i>Ketentuan Voucher Garansi</div>
          <div class="card-body">
            <p class="small text-secondary mb-2">Edit ketentuan yang muncul di voucher garansi QR. Setiap baris akan menjadi nomor urut (1, 2, 3...).</p>
            <form method="POST" action="/admin/settings/voucher-terms">
              <input type="hidden" name="_csrf" value="<%= csrf %>">
              <div class="mb-2">
                <textarea name="terms" class="form-control" rows="10" placeholder="Masukkan ketentuan, satu per baris"><%= typeof voucherTerms !== 'undefined' ? voucherTerms : '' %></textarea>
              </div>
              <button type="submit" class="btn btn-primary">Simpan Ketentuan</button>
            </form>
            <hr>
            <h6 class="fw-bold">Pratinjau:</h6>
            <ol class="small text-muted">
              <% if (typeof voucherTerms !== 'undefined' && voucherTerms) { %>
                <% voucherTerms.split('\n').forEach(function(line) { if (line.trim()) { %>
                <li><%= line.trim() %></li>
                <% }}) %>
              <% } else { %>
                <li class="text-secondary">Belum ada ketentuan. Simpan ketentuan terlebih dahulu.</li>
              <% } %>
            </ol>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<div class="modal fade" id="addUserModal">
  <div class="modal-dialog">
    <form method="POST" action="/admin/settings/user/create" class="modal-content">
      <input type="hidden" name="_csrf" value="<%= csrf %>">
      <div class="modal-header"><h5 class="modal-title">Tambah User Baru</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <div class="mb-2"><label class="form-label small">Nama Lengkap</label><input name="name" class="form-control" required></div>
        <div class="mb-2"><label class="form-label small">Username</label><input name="username" class="form-control" required></div>
        <div class="mb-2"><label class="form-label small">Password</label><input name="password" type="password" class="form-control" required></div>
        <div class="mb-2"><label class="form-label small">Role</label>
          <select name="role" class="form-select">
            <option value="admin">Admin</option>
            <option value="management">Management</option>
            <option value="teknisi">Teknisi</option>
            <option value="cs">Customer Service</option>
          </select>
        </div>
        <div class="mb-2"><label class="form-label small">No. HP (untuk WA)</label><input name="phone" class="form-control" placeholder="08123456789"></div>
        <div class="mb-2"><label class="form-label small">Email</label><input name="email" type="email" class="form-control"></div>
      </div>
      <div class="modal-footer"><button type="submit" class="btn btn-primary">Simpan</button></div>
    </form>
  </div>
</div>

<div class="modal fade" id="editUserModal">
  <div class="modal-dialog">
    <form method="POST" class="modal-content" id="editUserForm">
      <input type="hidden" name="_csrf" value="<%= csrf %>">
      <div class="modal-header"><h5 class="modal-title">Edit User</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <div class="mb-2"><label class="form-label small">Nama Lengkap</label><input name="name" id="editName" class="form-control" required></div>
        <div class="mb-2"><label class="form-label small">Username</label><input name="username" id="editUsername" class="form-control" required></div>
        <div class="mb-2"><label class="form-label small">Role</label>
          <select name="role" id="editRole" class="form-select">
            <option value="admin">Admin</option>
            <option value="management">Management</option>
            <option value="cs">Customer Service</option>
          </select>
        </div>
        <div class="mb-2"><label class="form-label small">No. HP</label><input name="phone" id="editPhone" class="form-control"></div>
        <div class="mb-2"><label class="form-label small">Email</label><input name="email" id="editEmail" type="email" class="form-control"></div>
        <div class="mb-2"><label class="form-label small">Password Baru (kosongkan jika tidak diubah)</label><input name="password" type="password" class="form-control"></div>
      </div>
      <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button><button type="submit" class="btn btn-primary">Simpan</button></div>
    </form>
  </div>
</div>

<hr class="mt-4">
<div class="text-center">
  <a href="/admin/debug-logs" class="text-secondary small text-decoration-none" target="_blank"><i class="bi bi-bug me-1"></i>Debug Logs</a>
</div>

<script>
function editUser(id, name, username, role, phone, email) {
  document.getElementById('editUserForm').action = '/admin/settings/user/' + id;
  document.getElementById('editName').value = name;
  document.getElementById('editUsername').value = username;
  document.getElementById('editRole').value = role;
  document.getElementById('editPhone').value = phone;
  document.getElementById('editEmail').value = email;
}
</script>
<%- include('../partials/footer') %>