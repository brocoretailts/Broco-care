<%- include('../partials/header') %>
<div class="d-flex">
  <%- include('../partials/sidebar') %>
  <main class="main-content">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h4 class="fw-bold mb-0"><i class="bi bi-ticket me-2"></i>Ticket Saya</h4>
      <a href="/admin/tickets/create" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> Buat Ticket</a>
    </div>
    <div class="card border-0 shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr><th>Ticket</th><th>Customer</th><th>Keluhan</th><th>Status</th><th>Tanggal</th></tr>
          </thead>
          <tbody>
            <% tickets.forEach(function(t) { %>
            <tr>
              <td class="fw-semibold"><%= t.ticket_no %></td>
              <td><%= t.customer_name %></td>
              <td class="small"><%= (t.keluhan || '').substring(0, 60) %></td>
              <td><span class="badge bg-<%= t.status === 'waiting' ? 'warning' : t.status === 'approval' ? 'warning text-white' : t.status === 'scheduled' ? 'primary' : t.status === 'on_progress' ? 'purple' : t.status === 'completed' ? 'success' : 'danger' %>"><%= t.status %></span></td>
              <td class="small text-secondary"><%= t.created_at %></td>
            </tr>
            <% }) %>
            <% if (!tickets.length) { %>
            <tr><td colspan="5" class="text-center text-secondary py-3">Belum ada ticket</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>