<%- include('../partials/header') %>
<div class="d-flex">
  <%- include('../partials/sidebar') %>
  <main class="main-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h4 class="fw-bold mb-0"><i class="bi bi-clock-history me-2"></i>Riwayat Approval</h4>
      <a href="/management/approval" class="btn btn-sm btn-outline-primary"><i class="bi bi-arrow-left"></i> Kembali</a>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>Tanggal</th>
              <th>Ticket</th>
              <th>Customer</th>
              <th>Aksi</th>
              <th>Keputusan</th>
              <th>Catatan</th>
              <th>Oleh</th>
            </tr>
          </thead>
          <tbody>
            <% logs.forEach(function(l) { %>
            <tr>
              <td class="small"><%= l.created_at %></td>
              <td><a href="/admin/tickets/<%= l.ticket_id %>" class="text-decoration-none"><%= l.ticket_no || '#'+l.ticket_id %></a></td>
              <td><%= l.customer_name || '-' %></td>
              <td>
                <% if (l.action === 'approve') { %><span class="badge bg-success">Disetujui</span>
                <% } else if (l.action === 'reject') { %><span class="badge bg-danger">Ditolak</span>
                <% } else if (l.action === 'reset') { %><span class="badge bg-warning text-dark">Reset</span>
                <% } else { %><span class="badge bg-secondary"><%= l.action %></span><% } %>
              </td>
              <td><%= l.decision || '-' %></td>
              <td class="small text-muted"><%= l.comment ? l.comment.substring(0, 100) : '-' %></td>
              <td class="small"><%= l.user_name || '-' %></td>
            </tr>
            <% }) %>
            <% if (logs.length === 0) { %>
            <tr><td colspan="7" class="text-center py-4 text-secondary">Belum ada riwayat</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
