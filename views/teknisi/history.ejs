<%- include('../partials/header') %>
<div class="d-flex">
  <%- include('../partials/sidebar') %>
  <main class="main-content">
    <h4 class="fw-bold mb-4"><i class="bi bi-clock-history me-2"></i>Riwayat Kunjungan</h4>

    <div class="card border-0 shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr><th>Ticket</th><th>Customer</th><th>Produk</th><th>Alamat</th><th>No. HP</th><th>Tanggal</th><th>Solusi</th><th></th></tr>
          </thead>
          <tbody>
            <% visits.forEach(function(v) { %>
            <tr>
              <td class="fw-semibold small"><%= v.ticket_no %></td>
              <td><%= v.customer_name %></td>
              <td><%= v.nama_produk %></td>
              <td class="small"><%= v.customer_alamat %>, <%= v.customer_kota %><%= v.customer_provinsi ? ', '+v.customer_provinsi : '' %></td>
              <td><%= v.customer_hp %></td>
              <td><%= v.tanggal %></td>
              <td><span class="badge bg-success"><%= v.solusi %></span></td>
              <td><a href="/teknisi/visit/<%= v.ticket_id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a></td>
            </tr>
            <% }) %>
            <% if (visits.length === 0) { %>
            <tr><td colspan="8" class="text-center text-secondary py-4">Belum ada kunjungan</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
